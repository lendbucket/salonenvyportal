  @@index([staffMemberId])
  @@map("performance_bonuses")
}

model RebookRecord {
  id                String    @id @default(cuid())
  staffMemberId     String
  locationId        String
  clientSquareId    String
  appointmentDate   DateTime
  rebookedAt        DateTime?
  wasRebooked       Boolean   @default(false)
  nextAppointmentId String?
  createdAt         DateTime  @default(now())

  @@index([staffMemberId])
  @@index([locationId])
  @@map("rebook_records")
}

// ═══════════════════════════════════════
// Feature 3: Reputation Management
// ═══════════════════════════════════════

model ReviewRequest {
  id               String    @id @default(cuid())
  locationId       String
  clientSquareId   String
  clientName       String
  clientPhone      String?
  clientEmail      String?
  staffMemberId    String?
  stylistName      String?
  appointmentDate  DateTime
  checkoutTime     DateTime
  sendAt           DateTime
  sentAt           DateTime?
  status           String    @default("scheduled")
  channel          String    @default("sms")
  rating           Int?
  feedback         String?
  googleReviewSent Boolean   @default(false)
  responseAt       DateTime?
  createdAt        DateTime  @default(now())

  @@index([status, sendAt])
  @@index([locationId])
  @@map("review_requests")
}

// ═══════════════════════════════════════
// Feature 4: Permissions Dashboard
// ═══════════════════════════════════════

model PortalPermission {
  id            String   @id @default(cuid())
  locationId    String?
  staffMemberId String?
  role          String
  feature       String
  action        String
  granted       Boolean  @default(true)
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([locationId, staffMemberId, role, feature, action])
  @@index([role, feature])
  @@index([staffMemberId])
  @@map("portal_permissions")
}

// ═══════════════════════════════════════
// Feature 5: Churn Predictor
// ═══════════════════════════════════════

model ChurnPrediction {
  id                   String    @id @default(cuid())
  locationId           String
  clientSquareId       String
  clientName           String
  clientPhone          String?
  clientEmail          String?
  riskScore            Float
  riskLevel            String
  lastVisitDate        DateTime?
  avgDaysBetweenVisits Float?
  daysSinceLastVisit   Int?
  totalVisits          Int       @default(0)
  totalSpend           Float     @default(0)
  predictedChurnDate   DateTime?
  outreachSent         Boolean   @default(false)
  outreachSentAt       DateTime?
  outreachResponse     String?
  wonBack              Boolean   @default(false)
  calculatedAt         DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([locationId, clientSquareId])
  @@index([locationId, riskLevel])
  @@index([riskScore])
  @@map("churn_predictions")
}

// ═══════════════════════════════════════
// Feature 6: Reyna AI Persistent Learning
// ═══════════════════════════════════════

model ReynaConversation {
  id             String   @id @default(cuid())
  sessionId      String   @unique
  userId         String
  locationId     String?
  messages       Json
  topics         String[]
  insights       Json?
  userIntent     String?
  resolved       Boolean  @default(false)
  feedbackRating Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([locationId])
  @@map("reyna_conversations")
}

model ReynaKnowledge {
  id          String   @id @default(cuid())
  category    String
  key         String
  value       Json
  confidence  Float    @default(1.0)
  sourceCount Int      @default(1)
  lastUpdated DateTime @default(now())
  locationId  String?
  createdAt   DateTime @default(now())

  @@unique([category, key, locationId])
  @@index([category])
  @@map("reyna_knowledge")
}

// ═══════════════════════════════════════
// Agent System
// ═══════════════════════════════════════

model Agent {
  id                String   @id @default(cuid())
  name              String   @unique
  displayName       String
  description       String   @db.Text
  status            String   @default("paused")

  config            Json
  schedule          String?

  totalRuns         Int      @default(0)
  totalDrafted      Int      @default(0)
  totalApproved     Int      @default(0)
  totalSent         Int      @default(0)
  totalRecovered    Int      @default(0)
  revenueAttributed Float    @default(0)

  lastRunAt         DateTime?
  nextRunAt         DateTime?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  runs              AgentRun[]
  drafts            AgentDraft[]

  @@map("agents")
}

model AgentRun {
  id                  String    @id @default(cuid())
  agentId             String
  status              String

  candidatesEvaluated Int       @default(0)
  draftsCreated       Int       @default(0)
  errorsEncountered   Int       @default(0)

  startedAt           DateTime  @default(now())
  completedAt         DateTime?
  errorMessage        String?   @db.Text

  agent               Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  drafts              AgentDraft[]

  @@index([agentId, startedAt])
  @@map("agent_runs")
}

model AgentDraft {
  id                  String    @id @default(cuid())
  agentId             String
  runId               String

  clientId            String

  reasoning           String    @db.Text
  priority            Int

  channel             String
  messageBody         String    @db.Text
  proposedOffer       String?
  proposedSendAt      DateTime

  status              String    @default("pending")
  reviewedById        String?
  reviewedAt          DateTime?
  rejectionReason     String?

  marketingMessageId  String?
  sentAt              DateTime?

  convertedAt         DateTime?
  conversionRevenue   Float?

  cancelledAt         DateTime?
  cancelledById       String?
  editedAt            DateTime?
  editedById          String?

  createdAt           DateTime  @default(now())

  agent               Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  run                 AgentRun  @relation(fields: [runId], references: [id], onDelete: Cascade)
  client              Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([agentId, status])
  @@index([clientId])
  @@index([proposedSendAt])
  @@index([status, proposedSendAt])
  @@map("agent_drafts")
}

// ═══════════════════════════════════════
// SMS Inbox
// ═══════════════════════════════════════

model InboundMessage {
  id                  String    @id @default(cuid())
  channel             String
  fromNumber          String
  toNumber            String
  clientId            String?
  replyToRecipientId  String?
  body                String    @db.Text
  numMediaItems       Int       @default(0)
  mediaUrls           String[]
  twilioMessageSid    String    @unique
  twilioAccountSid    String?
  status              String    @default("unread")
  intent              String?
  intentConfidence    Float?
  replyDraft          String?   @db.Text
  repliedById         String?
  repliedAt           DateTime?
  replyMessageId      String?
  receivedAt          DateTime  @default(now())

  isImportant         Boolean   @default(false)
  isFromBlockedNumber Boolean   @default(false)

  client              Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([status, receivedAt])
  @@index([clientId])
  @@index([fromNumber])
  @@index([replyToRecipientId])
  @@map("inbound_messages")
}

model BlockedNumber {
  id          String    @id @default(cuid())
  phoneNumber String    @unique
  reason      String?
  blockedById String
  blockedAt   DateTime  @default(now())

  @@map("blocked_numbers")
}
