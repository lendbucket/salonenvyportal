generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  MANAGER
  STYLIST
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         UserRole @default(STYLIST)
  locationId   String?
  inviteStatus String   @default("NOT_INVITED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  location     Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  staffMember  StaffMember?
  accounts     Account[]
  sessions     Session[]
  suiteSubscription SuiteSubscription?
  taxReceipts       TaxReceipt[]
  mileageLogs       MileageLog[]
  @@map("users")
}

model Location {
  id               String @id @default(cuid())
  name             String
  squareLocationId String @unique
  address          String
  phone            String
  staffMembers           StaffMember[]
  inventoryItems         InventoryItem[]
  users                  User[]
  schedules              Schedule[]
  purchaseOrders         PurchaseOrder[]
  onboardingEnrollments  OnboardingEnrollment[]
  @@map("locations")
}

model StaffMember {
  id                 String   @id @default(cuid())
  userId             String?  @unique
  locationId         String
  squareTeamMemberId String?  @unique
  fullName           String
  email              String?
  phone              String?
  position           String   @default("stylist")
  isActive           Boolean  @default(true)
  inviteStatus       String   @default("not_invited")
  tdlrLicenseNumber  String?
  tdlrStatus         String?
  tdlrExpirationDate DateTime?
  tdlrVerifiedAt     DateTime?
  tdlrHolderName     String?
  createdAt          DateTime @default(now())
  location           Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user               User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts             Shift[]
  conductRecords     ConductRecord[]
  @@map("staff_members")
}

model InventoryItem {
  id               String   @id @default(cuid())
  locationId       String
  brand            String
  productName      String
  category         String
  shadeOrVolume    String?
  unitType         String?
  quantityOnHand   Float    @default(0)
  reorderThreshold Float    @default(2)
  costPerUnit      Float?
  ouncesPerUnit    Float?
  ouncesPerService Float?
  ouncesOnHand     Float?
  supplier         String?
  sku              String?
  expirationDate   DateTime?
  lastRestocked    DateTime?
  reorderQty       Int      @default(6)
  approvalStatus   String   @default("pending")
  isLowStock       Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  location         Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  @@map("inventory_items")
}

model Schedule {
  id            String    @id @default(cuid())
  locationId    String
  weekStart     DateTime
  weekEnd       DateTime
  status        String    @default("draft")
  createdById   String
  submittedAt   DateTime?
  approvedAt    DateTime?
  approvedById  String?
  rejectedAt    DateTime?
  rejectionNote String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  shifts        Shift[]
  location      Location  @relation(fields: [locationId], references: [id])
  @@map("schedules")
}

model Shift {
  id            String      @id @default(cuid())
  scheduleId    String
  staffMemberId String
  date          DateTime
  startTime     String
  endTime       String
  isTimeOff     Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
  schedule      Schedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id])
  @@map("shifts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model AdminAlert {
  id        String   @id @default(cuid())
  title     String
  body      String
  severity  String   @default("info")
  createdAt DateTime @default(now())
  @@map("admin_alerts")
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  poNumber        String   @unique
  locationId      String
  status          String   @default("draft")
  supplier        String
  totalAmount     Float    @default(0)
  notes           String?
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  orderedAt       DateTime?
  receivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  items           PurchaseOrderItem[]
  location        Location @relation(fields: [locationId], references: [id])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String        @id @default(cuid())
  purchaseOrderId   String
  inventoryItemId   String?
  brand             String
  productName       String
  shadeOrVolume     String?
  unitType          String?
  quantityOrdered   Int
  quantityReceived  Int           @default(0)
  costPerUnit       Float         @default(0)
  totalCost         Float         @default(0)
  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  @@map("purchase_order_items")
}

model AnonymousComplaint {
  id          String   @id @default(cuid())
  category    String
  locationId  String?
  message     String
  isReviewed  Boolean  @default(false)
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime @default(now())
  @@map("anonymous_complaints")
}

model ConductRecord {
  id              String   @id @default(cuid())
  staffMemberId   String
  issuedById      String
  severity        String
  category        String
  title           String
  description     String
  actionTaken     String?
  followUpDate    DateTime?
  isAcknowledged  Boolean  @default(false)
  acknowledgedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  staffMember     StaffMember @relation(fields: [staffMemberId], references: [id])
  @@map("conduct_records")
}

model OnboardingEnrollment {
  id                    String    @id @default(cuid())
  inviteToken           String    @unique @default(cuid())
  email                 String
  firstName             String
  lastName              String
  locationId            String
  role                  UserRole  @default(STYLIST)
  status                String    @default("pending")

  // Personal Info
  phone                 String?
  dateOfBirth           String?
  address               String?
  city                  String?
  state                 String?
  zip                   String?

  // W-9 Info
  w9LegalName           String?
  w9BusinessName        String?
  w9TaxClassification   String?
  w9Ssn                 String?
  w9Ein                 String?
  w9Address             String?
  w9CertifiedAt         DateTime?

  // Direct Deposit
  ddBankName            String?
  ddRoutingNumber       String?
  ddAccountNumber       String?
  ddAccountType         String?
  ddNameOnAccount       String?

  // License Info
  licenseNumber         String?
  licenseState          String?
  licenseExpiration     String?
  licenseType           String?

  // Emergency Contact
  emergencyName         String?
  emergencyRelationship String?
  emergencyPhone        String?

  // Agreement / Signature
  signatureData         String?   @db.Text
  signedLegalName       String?
  signedSsnLast4        String?
  signedDate            String?
  agreementSignedAt     DateTime?

  // Compliance Acknowledgments
  ackPolicies           Boolean   @default(false)
  ackConfidentiality    Boolean   @default(false)
  ackAtWill             Boolean   @default(false)
  ackSafetyProtocol     Boolean   @default(false)
  ackTechPolicy         Boolean   @default(false)

  // Verification
  verificationCode      String?
  squareTeamMemberId    String?

  completedAt           DateTime?
  expiresAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt

  location              Location  @relation(fields: [locationId], references: [id])
  @@map("onboarding_enrollments")
}

model SuiteSubscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  status    String   @default("active")
  plan      String   @default("monthly")
  price     Float    @default(40)
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("suite_subscriptions")
}

model TaxReceipt {
  id           String   @id @default(cuid())
  userId       String
  imageData    String?  @db.Text
  vendor       String?
  amount       Float?
  category     String?
  description  String?
  receiptDate  DateTime?
  isDeductible Boolean  @default(true)
  aiAnalysis   String?  @db.Text
  taxYear      Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("tax_receipts")
}

model MileageLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  purpose   String
  miles     Float
  amount    Float
  notes     String?
  taxYear   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("mileage_logs")
}
