generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  MANAGER
  STYLIST
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         UserRole @default(STYLIST)
  locationId   String?
  inviteStatus String   @default("NOT_INVITED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  location     Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  staffMember  StaffMember?
  accounts     Account[]
  sessions     Session[]
  suiteSubscription   SuiteSubscription?
  taxReceipts         TaxReceipt[]
  mileageLogs         MileageLog[]
  quarterlyPayments   QuarterlyPayment[]
  taxYears            TaxYear[]
  creditProfile       CreditProfile?
  disputeLetters      DisputeLetter[]
  incomeVerifications IncomeVerification[]
  insuranceProfile    InsuranceProfile?
  incidentReports     IncidentReport[]
  otherIncome         OtherIncome[]
  courseCompletions    CourseCompletion[]
  tdlrLicenseRenewal  TdlrLicenseRenewal?
  healthProfile        HealthProfile?
  videoSubmissions     VideoSubmission[] @relation("VideoSubmissions")
  // payrollPeriodsPaid removed — PayrollPeriod no longer has User relation
  alertsCreated        AdminAlert[]    @relation("AlertsCreated")
  alertReads           AlertRead[]
  auditLogs            AuditLog[]
  @@map("users")
}

model Location {
  id               String @id @default(cuid())
  name             String
  squareLocationId String @unique
  address          String
  phone            String
  staffMembers           StaffMember[]
  inventoryItems         InventoryItem[]
  users                  User[]
  schedules              Schedule[]
  purchaseOrders         PurchaseOrder[]
  onboardingEnrollments  OnboardingEnrollment[]
  videoSubmissions       VideoSubmission[]
  // payrollPeriods removed — PayrollPeriod no longer has Location relation
  alerts                 AdminAlert[]
  auditLogs              AuditLog[]
  socialToken            SocialToken?
  socialComments         SocialComment[]
  socialAnalytics        SocialAnalytics[]
  @@map("locations")
}

model StaffMember {
  id                 String   @id @default(cuid())
  userId             String?  @unique
  locationId         String
  squareTeamMemberId String?  @unique
  fullName           String
  email              String?
  phone              String?
  position           String   @default("stylist")
  isActive           Boolean  @default(true)
  inviteStatus       String   @default("not_invited")
  tdlrLicenseNumber  String?
  tdlrStatus         String?
  tdlrExpirationDate DateTime?
  tdlrVerifiedAt     DateTime?
  tdlrHolderName     String?
  createdAt          DateTime @default(now())
  location           Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user               User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts             Shift[]
  conductRecords     ConductRecord[]
  @@map("staff_members")
}

model InventoryItem {
  id               String   @id @default(cuid())
  locationId       String
  brand            String
  productName      String
  category         String
  shadeOrVolume    String?
  unitType         String?
  quantityOnHand   Float    @default(0)
  reorderThreshold Float    @default(2)
  costPerUnit      Float?
  ouncesPerUnit    Float?
  ouncesPerService Float?
  ouncesOnHand     Float?
  supplier         String?
  sku              String?
  expirationDate   DateTime?
  lastRestocked    DateTime?
  reorderQty       Int      @default(6)
  approvalStatus   String   @default("pending")
  isLowStock       Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  location         Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  @@map("inventory_items")
}

model Schedule {
  id            String    @id @default(cuid())
  locationId    String
  weekStart     DateTime
  weekEnd       DateTime
  status        String    @default("draft")
  createdById   String
  submittedAt   DateTime?
  approvedAt    DateTime?
  approvedById  String?
  rejectedAt    DateTime?
  rejectionNote String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  shifts        Shift[]
  location      Location  @relation(fields: [locationId], references: [id])
  @@map("schedules")
}

model Shift {
  id            String      @id @default(cuid())
  scheduleId    String
  staffMemberId String
  date          DateTime
  startTime     String
  endTime       String
  isTimeOff     Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
  schedule      Schedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id])
  @@map("shifts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model AdminAlert {
  id          String      @id @default(cuid())
  type        String      @default("broadcast")
  title       String
  body        String
  severity    String      @default("info")
  locationId  String?
  createdById String?
  expiresAt   DateTime?
  createdAt   DateTime    @default(now())
  location    Location?   @relation(fields: [locationId], references: [id])
  createdBy   User?       @relation("AlertsCreated", fields: [createdById], references: [id])
  reads       AlertRead[]
  @@map("admin_alerts")
}

model AlertRead {
  id      String     @id @default(cuid())
  alertId String
  userId  String
  readAt  DateTime   @default(now())
  alert   AdminAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id])
  @@unique([alertId, userId])
  @@map("alert_reads")
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  poNumber        String   @unique
  locationId      String
  status          String   @default("draft")
  supplier        String
  totalAmount     Float    @default(0)
  notes           String?
  createdById     String
  approvedById    String?
  approvedAt      DateTime?
  orderedAt       DateTime?
  receivedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  items           PurchaseOrderItem[]
  location        Location @relation(fields: [locationId], references: [id])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                String        @id @default(cuid())
  purchaseOrderId   String
  inventoryItemId   String?
  brand             String
  productName       String
  shadeOrVolume     String?
  unitType          String?
  quantityOrdered   Int
  quantityReceived  Int           @default(0)
  costPerUnit       Float         @default(0)
  totalCost         Float         @default(0)
  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  @@map("purchase_order_items")
}

model AnonymousComplaint {
  id          String   @id @default(cuid())
  category    String
  locationId  String?
  message     String
  isReviewed  Boolean  @default(false)
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime @default(now())
  @@map("anonymous_complaints")
}

model ConductRecord {
  id              String   @id @default(cuid())
  staffMemberId   String
  issuedById      String
  severity        String
  category        String
  title           String
  description     String
  actionTaken     String?
  followUpDate    DateTime?
  isAcknowledged  Boolean  @default(false)
  acknowledgedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  staffMember     StaffMember @relation(fields: [staffMemberId], references: [id])
  @@map("conduct_records")
}

model OnboardingEnrollment {
  id                    String    @id @default(cuid())
  inviteToken           String    @unique @default(cuid())
  email                 String
  firstName             String
  lastName              String
  locationId            String
  role                  UserRole  @default(STYLIST)
  status                String    @default("pending")

  // Personal Info
  phone                 String?
  dateOfBirth           String?
  address               String?
  city                  String?
  state                 String?
  zip                   String?

  // W-9 Info
  w9LegalName           String?
  w9BusinessName        String?
  w9TaxClassification   String?
  w9Ssn                 String?
  w9Ein                 String?
  w9Address             String?
  w9CertifiedAt         DateTime?

  // Direct Deposit
  ddBankName            String?
  ddRoutingNumber       String?
  ddAccountNumber       String?
  ddAccountType         String?
  ddNameOnAccount       String?

  // License Info
  licenseNumber         String?
  licenseState          String?
  licenseExpiration     String?
  licenseType           String?

  // Emergency Contact
  emergencyName         String?
  emergencyRelationship String?
  emergencyPhone        String?

  // Agreement / Signature
  signatureData         String?   @db.Text
  signedLegalName       String?
  signedSsnLast4        String?
  signedDate            String?
  agreementSignedAt     DateTime?

  // Compliance Acknowledgments
  ackPolicies           Boolean   @default(false)
  ackConfidentiality    Boolean   @default(false)
  ackAtWill             Boolean   @default(false)
  ackSafetyProtocol     Boolean   @default(false)
  ackTechPolicy         Boolean   @default(false)

  // Verification
  verificationCode      String?
  squareTeamMemberId    String?

  completedAt           DateTime?
  expiresAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt

  location              Location  @relation(fields: [locationId], references: [id])
  @@map("onboarding_enrollments")
}

model SuiteSubscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  status    String   @default("active")
  plan      String   @default("monthly")
  price     Float    @default(40)
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("suite_subscriptions")
}

model TaxReceipt {
  id           String   @id @default(cuid())
  userId       String
  imageData    String?  @db.Text
  vendor       String?
  amount       Float?
  category     String?
  description  String?
  receiptDate  DateTime?
  isDeductible Boolean  @default(true)
  aiAnalysis   String?  @db.Text
  taxYear      Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  scheduleC_line   String?
  isSplit          Boolean  @default(false)
  businessPercent  Float    @default(100)
  businessAmount   Float?
  isDuplicate      Boolean  @default(false)
  merchantCategory String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("tax_receipts")
}

model MileageLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  purpose   String
  miles     Float
  amount    Float
  notes     String?
  taxYear   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  fromLocation String?
  toLocation   String?
  isRoundTrip  Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("mileage_logs")
}

model QuarterlyPayment {
  id              String    @id @default(cuid())
  userId          String
  taxYear         Int
  quarter         Int
  dueDate         DateTime
  estimatedAmount Float
  actualAmount    Float?
  paidAt          DateTime?
  confirmationNum String?
  status          String    @default("upcoming")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, taxYear, quarter])
  @@map("quarterly_payments")
}

model TaxYear {
  id              String  @id @default(cuid())
  userId          String
  year            Int
  totalIncome     Float   @default(0)
  totalDeductions Float   @default(0)
  estimatedTax    Float   @default(0)
  isFinalized     Boolean @default(false)
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, year])
  @@map("tax_years")
}

model CreditProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  currentScore          Int?
  scoreHistory          Json?
  tier                  String?
  reportingStartDate    DateTime?
  totalPaymentsReported Int       @default(0)
  bureausReported       Json?
  estimatedScoreGain    Int       @default(0)
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @default(now()) @updatedAt
  user                  User      @relation(fields: [userId], references: [id])
  @@map("credit_profiles")
}

model DisputeLetter {
  id            String    @id @default(cuid())
  userId        String
  bureau        String
  creditorName  String
  accountNumber String?
  errorType     String
  description   String
  letterContent String    @db.Text
  status        String    @default("draft")
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id])
  @@map("dispute_letters")
}

model IncomeVerification {
  id           String   @id @default(cuid())
  userId       String
  generatedAt  DateTime @default(now())
  monthlyAvg   Float
  annualIncome Float
  incomeMonths Int
  consistency  String
  purpose      String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  @@map("income_verifications")
}

model InsuranceProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  status          String    @default("none")
  policyNumber    String?
  provider        String?   @default("Next Insurance")
  coverageAmount  Float?    @default(1000000)
  monthlyPremium  Float?    @default(15)
  startDate       DateTime?
  expirationDate  DateTime?
  certificateUrl  String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  user            User      @relation(fields: [userId], references: [id])
  @@map("insurance_profiles")
}

model IncidentReport {
  id               String   @id @default(cuid())
  userId           String
  incidentDate     DateTime
  clientName       String?
  incidentType     String
  description      String   @db.Text
  witnessName      String?
  witnessContact   String?
  medicalAttention Boolean  @default(false)
  claimFiled       Boolean  @default(false)
  claimNumber      String?
  status           String   @default("documented")
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id])
  @@map("incident_reports")
}

model OtherIncome {
  id        String   @id @default(cuid())
  userId    String
  source    String
  amount    Float
  date      DateTime
  notes     String?
  taxYear   Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  @@map("other_income")
}

model EduCourse {
  id              String   @id @default(cuid())
  title           String
  description     String
  category        String
  instructor      String?
  durationMinutes Int      @default(30)
  level           String   @default("beginner")
  thumbnailUrl    String?
  videoUrl        String?
  isFeatured      Boolean  @default(false)
  isTdlrApproved  Boolean  @default(false)
  tdlrHours       Float    @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  completions     CourseCompletion[]
  submission      VideoSubmission?
  @@map("edu_courses")
}

model CourseCompletion {
  id          String    @id @default(cuid())
  userId      String
  courseId     String
  completedAt DateTime  @default(now())
  score       Int?
  notes       String?
  user        User      @relation(fields: [userId], references: [id])
  course      EduCourse @relation(fields: [courseId], references: [id])
  @@unique([userId, courseId])
  @@map("course_completions")
}

model TdlrLicenseRenewal {
  id                String    @id @default(cuid())
  userId            String    @unique
  licenseNumber     String?
  licenseExpiration DateTime?
  ceHoursRequired   Float     @default(8)
  ceHoursCompleted  Float     @default(0)
  renewalDueDate    DateTime?
  lastReminderSent  DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  user              User      @relation(fields: [userId], references: [id])
  @@map("tdlr_license_renewals")
}

model HealthProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  enrollmentStatus  String    @default("none")
  planType          String?
  provider          String?
  monthlyPremium    Float?
  deductible        Float?
  hasHsa            Boolean   @default(false)
  hsaContribution   Float?
  hasDental         Boolean   @default(false)
  hasVision         Boolean   @default(false)
  coverageStartDate DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt
  user              User      @relation(fields: [userId], references: [id])
  @@map("health_profiles")
}

model VideoSubmission {
  id               String     @id @default(cuid())
  submittedBy      String
  locationId       String
  title            String
  description      String
  url              String
  videoId          String?
  platform         String
  embedUrl         String?
  category         String
  suggestedHours   Float      @default(0)
  isTdlrCe         Boolean    @default(false)
  status           String     @default("pending")
  reviewedBy       String?
  reviewedAt       DateTime?
  rejectionReason  String?
  approvedCourseId String?    @unique
  approvedCourse   EduCourse? @relation(fields: [approvedCourseId], references: [id])
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @default(now()) @updatedAt
  submitter        User       @relation("VideoSubmissions", fields: [submittedBy], references: [id])
  location         Location   @relation(fields: [locationId], references: [id])
  @@map("video_submissions")
}

model PayrollPeriod {
  id              String         @id @default(cuid())
  locationId      String
  periodStart     DateTime
  periodEnd       DateTime
  status          String         @default("pending")
  paidAt          DateTime?
  paidBy          String?
  totalCommission Float          @default(0)
  totalTips       Float          @default(0)
  totalServices   Int            @default(0)
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @default(now()) @updatedAt
  entries         PayrollEntry[]
  @@map("payroll_periods")
}

model PayrollEntry {
  id              String        @id @default(cuid())
  periodId        String
  teamMemberId    String
  teamMemberName  String
  locationId      String
  serviceCount    Int           @default(0)
  serviceSubtotal Float         @default(0)
  commission      Float         @default(0)
  tips            Float         @default(0)
  totalPayout     Float         @default(0)
  period          PayrollPeriod @relation(fields: [periodId], references: [id])
  createdAt       DateTime      @default(now())
  @@map("payroll_entries")
}

model AuditLog {
  id         String    @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  userId     String?
  userEmail  String?
  userRole   String?
  locationId String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime  @default(now())
  user       User?     @relation(fields: [userId], references: [id])
  location   Location? @relation(fields: [locationId], references: [id])
  @@map("audit_logs")
}

model SocialPost {
  id           String    @id @default(cuid())
  locationId   String
  platform     String
  content      String    @db.Text
  imageUrls    Json?
  videoUrl     String?
  status       String    @default("draft")
  scheduledAt  DateTime?
  publishedAt  DateTime?
  fbPostId     String?
  igPostId     String?
  errorMessage String?
  reach        Int?
  likes        Int?
  comments     Int?
  shares       Int?
  impressions  Int?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  @@map("social_posts")
}

model SocialToken {
  id            String    @id @default(cuid())
  locationId    String    @unique
  fbPageId      String
  fbAccessToken String
  igAccountId   String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  location      Location  @relation(fields: [locationId], references: [id])
  @@map("social_tokens")
}

model SocialComment {
  id           String    @id @default(cuid())
  platform     String
  externalId   String
  postId       String?
  authorName   String
  authorAvatar String?
  message      String
  createdAt    DateTime  @default(now())
  locationId   String
  replied      Boolean   @default(false)
  replyText    String?
  repliedAt    DateTime?
  location     Location  @relation(fields: [locationId], references: [id])
  @@map("social_comments")
}

model SocialAnalytics {
  id             String   @id @default(cuid())
  locationId     String
  platform       String
  date           DateTime
  followersCount Int      @default(0)
  reach          Int      @default(0)
  impressions    Int      @default(0)
  engagement     Int      @default(0)
  postsCount     Int      @default(0)
  createdAt      DateTime @default(now())
  location       Location @relation(fields: [locationId], references: [id])
  @@unique([locationId, platform, date])
  @@map("social_analytics")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt
  @@map("system_settings")
}

model WaitlistEntry {
  id               String   @id @default(cuid())
  locationId       String
  customerName     String
  customerPhone    String
  customerEmail    String?
  requestedDate    DateTime
  requestedStylist String?
  requestedService String?
  notes            String?
  status           String   @default("waiting")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  @@map("waitlist_entries")
}
