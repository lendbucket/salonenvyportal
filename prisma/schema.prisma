// Connection URLs live in prisma.config.ts (Prisma ORM 7+).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  STYLIST
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         UserRole @default(STYLIST)
  locationId   String?
  createdAt    DateTime @default(now())

  @@map("users")
}

model Location {
  id               String @id @default(cuid())
  name             String
  squareLocationId String @unique
  address          String
  phone            String

  @@map("locations")
}
