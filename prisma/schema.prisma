generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  MANAGER
  STYLIST
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         UserRole @default(STYLIST)
  locationId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  @@map("users")
}

model Location {
  id               String @id @default(cuid())
  name             String
  squareLocationId String @unique
  address          String
  phone            String
  staffMembers     StaffMember[]
  inventoryItems   InventoryItem[]
  @@map("locations")
}

model StaffMember {
  id                 String   @id @default(cuid())
  userId             String?  @unique
  locationId         String
  squareTeamMemberId String?  @unique
  fullName           String
  email              String?
  phone              String?
  position           String   @default("stylist")
  isActive           Boolean  @default(true)
  inviteStatus       String   @default("not_invited")
  createdAt          DateTime @default(now())
  location           Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  @@map("staff_members")
}

model InventoryItem {
  id               String   @id @default(cuid())
  locationId       String
  brand            String
  productName      String
  category         String
  shadeOrVolume    String?
  unitType         String?
  quantityOnHand   Float    @default(0)
  reorderThreshold Float    @default(2)
  ouncesOnHand     Float?
  supplier         String?
  approvalStatus   String   @default("pending")
  isLowStock       Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  location         Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  @@map("inventory_items")
}

model AdminAlert {
  id        String   @id @default(cuid())
  title     String
  body      String
  severity  String   @default("info")
  createdAt DateTime @default(now())
  @@map("admin_alerts")
}
