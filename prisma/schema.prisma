model Client {
  id               String          @id @default(cuid())
  squareCustomerId String          @unique
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  totalVisits      Int             @default(0)
  totalSpend       Float           @default(0)
  lastVisitAt      DateTime?
  firstVisitAt     DateTime?
  locationId       String?
  notes            String?
  cardOnFile       Boolean         @default(false)
  stripeCustomerId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  formulas              ClientFormula[]
  optInRecords          OptInRecord[]
  messageRecipients     MessageRecipient[]
  smsMarketingConsent   Boolean   @default(true)
  smsConsentTimestamp   DateTime?
  smsConsentMethod      String?
  smsConsentSource      String?
  smsOptedOutAt         DateTime?
  smsLastEngagedAt      DateTime?
  squareNote          String?
  addressLine1        String?
  addressLine2        String?
  addressCity         String?
  addressState        String?
  addressZip          String?
  addressCountry      String?
  birthday            DateTime?
  squareReferenceId   String?
  emailUnsubscribed   Boolean?
  squareGroupIds      String[]            @default([])
  customAttributes    Json?
  lastSyncedAt        DateTime?

  // Cached aggregates from orders/appointments (computed by daily cron)
  lifetimeSpend           Float     @default(0)
  totalNoShows            Int       @default(0)
  totalCancellations      Int       @default(0)
  averageTicket           Float     @default(0)
  lastOrderAt             DateTime?
  daysBetweenVisits       Float?
  predictedNextVisitAt    DateTime?
  favoriteStaffMemberId   String?
  favoriteServiceCategory String?
  loyaltyScore            Float?
  engagementScore         Float?
  churnRiskScore          Float?
  vipTier                 String?
  valueTier               String?
  metricsLastComputedAt   DateTime?

  // Relations
  orders                  SquareOrder[]
  appointments            SquareAppointment[]
  payments                SquarePayment[]
  emailContact            EmailContact?
  agentDrafts             AgentDraft[]
  inboundMessages         InboundMessage[]

  @@index([lastSyncedAt])
  @@index([emailUnsubscribed])
  @@index([smsMarketingConsent])
  @@index([smsOptedOutAt])
  @@index([lifetimeSpend])
  @@index([vipTier])
  @@index([engagementScore])
  @@index([churnRiskScore])
  @@map("clients")
}

model SyncJob {
